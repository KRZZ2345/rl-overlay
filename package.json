{
  "name": "rl-overlay",
  "version": "1.0.0",
  "description": "Overlay Rocket League (sans injection) : streak, wins/losses de session, MMR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win zip"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.krzz.rloverlay",
    "productName": "RL Overlay",
    "win": {
      "target": "zip"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!config.json",
      "!session.json"
    ]
  }
}
